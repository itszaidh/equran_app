{"id":"043","title":"\u0627\u0644\u062f\u0639\u0627\u0621 \u0642\u0636\u0627\u0621 \u0627\u0644\u062f\u064a\u0646","text":["\u0627\u0644\u0644\u0647\u0645 \u0627\u0643\u0641\u0646\u064a \u0628\u062d\u0644\u0627\u0644\u0643 \u0639\u0646 \u062d\u0631\u0627\u0645\u0643 \u060c \u0648\u0623\u063a\u0646\u0646\u064a \u0628\u0641\u0636\u0644\u0643 \u0639\u0645\u0646 \u0633\u0648\u0627\u0643 ","\u0627\u0644\u0644\u0647\u0645 \u0625\u0646\u064a \u0623\u0639\u0648\u0630 \u0628\u0643 \u0645\u0646 \u0627\u0644\u0647\u0645 \u0648\u0627\u0644\u062d\u0632\u0646 \u060c \u0648\u0627\u0644\u0639\u062c\u0632 \u0648\u0627\u0644\u0643\u0633\u0644 \u060c\u0648\u0627\u0644\u0628\u062e\u0644 \u0648\u0627\u0644\u062c\u0628\u0646 \u0648\u0636\u0644\u0639 \u0627\u0644\u062f\u064a\u0646 \u0648\u063a\u0644\u0628\u0629 \u0627\u0644\u0631\u062c\u0627\u0644 "],"footnote":["\u0627\u0644\u062a\u0631\u0645\u0630\u064a 5/560 \u0648\u0627\u0646\u0638\u0631 \u0635\u062d\u064a\u062d \u0627\u0644\u062a\u0631\u0645\u0630\u064a3/ 180"," \u0627\u0644\u0628\u062e\u0627\u0631\u064a7/ 158"]}
