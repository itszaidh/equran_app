{
  "ayahs": [
    {
      "surah": 77,
      "ayah": 1,
      "text": "وَٱلۡمُرۡسَلَٰتِ عُرۡفٗا"
    },
    {
      "surah": 77,
      "ayah": 2,
      "text": "فَٱلۡعَٰصِفَٰتِ عَصۡفٗا"
    },
    {
      "surah": 77,
      "ayah": 3,
      "text": "وَٱلنَّٰشِرَٰتِ نَشۡرٗا"
    },
    {
      "surah": 77,
      "ayah": 4,
      "text": "فَٱلۡفَٰرِقَٰتِ فَرۡقٗا"
    },
    {
      "surah": 77,
      "ayah": 5,
      "text": "فَٱلۡمُلۡقِيَٰتِ ذِكۡرًا"
    },
    {
      "surah": 77,
      "ayah": 6,
      "text": "عُذۡرًا أَوۡ نُذۡرًا"
    },
    {
      "surah": 77,
      "ayah": 7,
      "text": "إِنَّمَا تُوعَدُونَ لَوَٰقِعٞ"
    },
    {
      "surah": 77,
      "ayah": 8,
      "text": "فَإِذَا ٱلنُّجُومُ طُمِسَتۡ"
    },
    {
      "surah": 77,
      "ayah": 9,
      "text": "وَإِذَا ٱلسَّمَآءُ فُرِجَتۡ"
    },
    {
      "surah": 77,
      "ayah": 10,
      "text": "وَإِذَا ٱلۡجِبَالُ نُسِفَتۡ"
    },
    {
      "surah": 77,
      "ayah": 11,
      "text": "وَإِذَا ٱلرُّسُلُ أُقِّتَتۡ"
    },
    {
      "surah": 77,
      "ayah": 12,
      "text": "لِأَيِّ يَوۡمٍ أُجِّلَتۡ"
    },
    {
      "surah": 77,
      "ayah": 13,
      "text": "لِيَوۡمِ ٱلۡفَصۡلِ"
    },
    {
      "surah": 77,
      "ayah": 14,
      "text": "وَمَآ أَدۡرَىٰكَ مَا يَوۡمُ ٱلۡفَصۡلِ"
    },
    {
      "surah": 77,
      "ayah": 15,
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ"
    },
    {
      "surah": 77,
      "ayah": 16,
      "text": "أَلَمۡ نُهۡلِكِ ٱلۡأَوَّلِينَ"
    },
    {
      "surah": 77,
      "ayah": 17,
      "text": "ثُمَّ نُتۡبِعُهُمُ ٱلۡأٓخِرِينَ"
    },
    {
      "surah": 77,
      "ayah": 18,
      "text": "كَذَٰلِكَ نَفۡعَلُ بِٱلۡمُجۡرِمِينَ"
    },
    {
      "surah": 77,
      "ayah": 19,
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ"
    },
    {
      "surah": 77,
      "ayah": 20,
      "text": "أَلَمۡ نَخۡلُقكُّم مِّن مَّآءٖ مَّهِينٖ"
    },
    {
      "surah": 77,
      "ayah": 21,
      "text": "فَجَعَلۡنَٰهُ فِي قَرَارٖ مَّكِينٍ"
    },
    {
      "surah": 77,
      "ayah": 22,
      "text": "إِلَىٰ قَدَرٖ مَّعۡلُومٖ"
    },
    {
      "surah": 77,
      "ayah": 23,
      "text": "فَقَدَرۡنَا فَنِعۡمَ ٱلۡقَٰدِرُونَ"
    },
    {
      "surah": 77,
      "ayah": 24,
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ"
    },
    {
      "surah": 77,
      "ayah": 25,
      "text": "أَلَمۡ نَجۡعَلِ ٱلۡأَرۡضَ كِفَاتًا"
    },
    {
      "surah": 77,
      "ayah": 26,
      "text": "أَحۡيَآءٗ وَأَمۡوَٰتٗا"
    },
    {
      "surah": 77,
      "ayah": 27,
      "text": "وَجَعَلۡنَا فِيهَا رَوَٰسِيَ شَٰمِخَٰتٖ وَأَسۡقَيۡنَٰكُم مَّآءٗ فُرَاتٗا"
    },
    {
      "surah": 77,
      "ayah": 28,
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ"
    },
    {
      "surah": 77,
      "ayah": 29,
      "text": "ٱنطَلِقُوٓاْ إِلَىٰ مَا كُنتُم بِهِۦ تُكَذِّبُونَ"
    },
    {
      "surah": 77,
      "ayah": 30,
      "text": "ٱنطَلِقُوٓاْ إِلَىٰ ظِلّٖ ذِي ثَلَٰثِ شُعَبٖ"
    },
    {
      "surah": 77,
      "ayah": 31,
      "text": "لَّا ظَلِيلٖ وَلَا يُغۡنِي مِنَ ٱللَّهَبِ"
    },
    {
      "surah": 77,
      "ayah": 32,
      "text": "إِنَّهَا تَرۡمِي بِشَرَرٖ كَٱلۡقَصۡرِ"
    },
    {
      "surah": 77,
      "ayah": 33,
      "text": "كَأَنَّهُۥ جِمَٰلَتٞ صُفۡرٞ"
    },
    {
      "surah": 77,
      "ayah": 34,
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ"
    },
    {
      "surah": 77,
      "ayah": 35,
      "text": "هَٰذَا يَوۡمُ لَا يَنطِقُونَ"
    },
    {
      "surah": 77,
      "ayah": 36,
      "text": "وَلَا يُؤۡذَنُ لَهُمۡ فَيَعۡتَذِرُونَ"
    },
    {
      "surah": 77,
      "ayah": 37,
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ"
    },
    {
      "surah": 77,
      "ayah": 38,
      "text": "هَٰذَا يَوۡمُ ٱلۡفَصۡلِۖ جَمَعۡنَٰكُمۡ وَٱلۡأَوَّلِينَ"
    },
    {
      "surah": 77,
      "ayah": 39,
      "text": "فَإِن كَانَ لَكُمۡ كَيۡدٞ فَكِيدُونِ"
    },
    {
      "surah": 77,
      "ayah": 40,
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ"
    },
    {
      "surah": 77,
      "ayah": 41,
      "text": "إِنَّ ٱلۡمُتَّقِينَ فِي ظِلَٰلٖ وَعُيُونٖ"
    },
    {
      "surah": 77,
      "ayah": 42,
      "text": "وَفَوَٰكِهَ مِمَّا يَشۡتَهُونَ"
    },
    {
      "surah": 77,
      "ayah": 43,
      "text": "كُلُواْ وَٱشۡرَبُواْ هَنِيٓـَٔۢا بِمَا كُنتُمۡ تَعۡمَلُونَ"
    },
    {
      "surah": 77,
      "ayah": 44,
      "text": "إِنَّا كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ"
    },
    {
      "surah": 77,
      "ayah": 45,
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ"
    },
    {
      "surah": 77,
      "ayah": 46,
      "text": "كُلُواْ وَتَمَتَّعُواْ قَلِيلًا إِنَّكُم مُّجۡرِمُونَ"
    },
    {
      "surah": 77,
      "ayah": 47,
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ"
    },
    {
      "surah": 77,
      "ayah": 48,
      "text": "وَإِذَا قِيلَ لَهُمُ ٱرۡكَعُواْ لَا يَرۡكَعُونَ"
    },
    {
      "surah": 77,
      "ayah": 49,
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ"
    },
    {
      "surah": 77,
      "ayah": 50,
      "text": "فَبِأَيِّ حَدِيثِۭ بَعۡدَهُۥ يُؤۡمِنُونَ"
    }
  ]
}
