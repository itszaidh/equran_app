{"ayahs":[{"surah":93,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ وَالضُّحَىٰ"},{"surah":93,"ayah":2,"text":"وَاللَّيْلِ إِذَا سَجَىٰ"},{"surah":93,"ayah":3,"text":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ"},{"surah":93,"ayah":4,"text":"وَلَلْآخِرَةُ خَيْرٌ لَكَ مِنَ الْأُولَىٰ"},{"surah":93,"ayah":5,"text":"وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰ"},{"surah":93,"ayah":6,"text":"أَلَمْ يَجِدْكَ يَتِيمًا فَآوَىٰ"},{"surah":93,"ayah":7,"text":"وَوَجَدَكَ ضَالًّا فَهَدَىٰ"},{"surah":93,"ayah":8,"text":"وَوَجَدَكَ عَائِلًا فَأَغْنَىٰ"},{"surah":93,"ayah":9,"text":"فَأَمَّا الْيَتِيمَ فَلَا تَقْهَرْ"},{"surah":93,"ayah":10,"text":"وَأَمَّا السَّائِلَ فَلَا تَنْهَرْ"},{"surah":93,"ayah":11,"text":"وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ"}]}