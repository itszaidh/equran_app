{"ayahs":[{"surah":80,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ عَبَسَ وَتَوَلَّىٰ"},{"surah":80,"ayah":2,"text":"أَنْ جَاءَهُ الْأَعْمَىٰ"},{"surah":80,"ayah":3,"text":"وَمَا يُدْرِيكَ لَعَلَّهُ يَزَّكَّىٰ"},{"surah":80,"ayah":4,"text":"أَوْ يَذَّكَّرُ فَتَنْفَعَهُ الذِّكْرَىٰ"},{"surah":80,"ayah":5,"text":"أَمَّا مَنِ اسْتَغْنَىٰ"},{"surah":80,"ayah":6,"text":"فَأَنْتَ لَهُ تَصَدَّىٰ"},{"surah":80,"ayah":7,"text":"وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ"},{"surah":80,"ayah":8,"text":"وَأَمَّا مَنْ جَاءَكَ يَسْعَىٰ"},{"surah":80,"ayah":9,"text":"وَهُوَ يَخْشَىٰ"},{"surah":80,"ayah":10,"text":"فَأَنْتَ عَنْهُ تَلَهَّىٰ"},{"surah":80,"ayah":11,"text":"كَلَّا إِنَّهَا تَذْكِرَةٌ"},{"surah":80,"ayah":12,"text":"فَمَنْ شَاءَ ذَكَرَهُ"},{"surah":80,"ayah":13,"text":"فِي صُحُفٍ مُكَرَّمَةٍ"},{"surah":80,"ayah":14,"text":"مَرْفُوعَةٍ مُطَهَّرَةٍ"},{"surah":80,"ayah":15,"text":"بِأَيْدِي سَفَرَةٍ"},{"surah":80,"ayah":16,"text":"كِرَامٍ بَرَرَةٍ"},{"surah":80,"ayah":17,"text":"قُتِلَ الْإِنْسَانُ مَا أَكْفَرَهُ"},{"surah":80,"ayah":18,"text":"مِنْ أَيِّ شَيْءٍ خَلَقَهُ"},{"surah":80,"ayah":19,"text":"مِنْ نُطْفَةٍ خَلَقَهُ فَقَدَّرَهُ"},{"surah":80,"ayah":20,"text":"ثُمَّ السَّبِيلَ يَسَّرَهُ"},{"surah":80,"ayah":21,"text":"ثُمَّ أَمَاتَهُ فَأَقْبَرَهُ"},{"surah":80,"ayah":22,"text":"ثُمَّ إِذَا شَاءَ أَنْشَرَهُ"},{"surah":80,"ayah":23,"text":"كَلَّا لَمَّا يَقْضِ مَا أَمَرَهُ"},{"surah":80,"ayah":24,"text":"فَلْيَنْظُرِ الْإِنْسَانُ إِلَىٰ طَعَامِهِ"},{"surah":80,"ayah":25,"text":"أَنَّا صَبَبْنَا الْمَاءَ صَبًّا"},{"surah":80,"ayah":26,"text":"ثُمَّ شَقَقْنَا الْأَرْضَ شَقًّا"},{"surah":80,"ayah":27,"text":"فَأَنْبَتْنَا فِيهَا حَبًّا"},{"surah":80,"ayah":28,"text":"وَعِنَبًا وَقَضْبًا"},{"surah":80,"ayah":29,"text":"وَزَيْتُونًا وَنَخْلًا"},{"surah":80,"ayah":30,"text":"وَحَدَائِقَ غُلْبًا"},{"surah":80,"ayah":31,"text":"وَفَاكِهَةً وَأَبًّا"},{"surah":80,"ayah":32,"text":"مَتَاعًا لَكُمْ وَلِأَنْعَامِكُمْ"},{"surah":80,"ayah":33,"text":"فَإِذَا جَاءَتِ الصَّاخَّةُ"},{"surah":80,"ayah":34,"text":"يَوْمَ يَفِرُّ الْمَرْءُ مِنْ أَخِيهِ"},{"surah":80,"ayah":35,"text":"وَأُمِّهِ وَأَبِيهِ"},{"surah":80,"ayah":36,"text":"وَصَاحِبَتِهِ وَبَنِيهِ"},{"surah":80,"ayah":37,"text":"لِكُلِّ امْرِئٍ مِنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ"},{"surah":80,"ayah":38,"text":"وُجُوهٌ يَوْمَئِذٍ مُسْفِرَةٌ"},{"surah":80,"ayah":39,"text":"ضَاحِكَةٌ مُسْتَبْشِرَةٌ"},{"surah":80,"ayah":40,"text":"وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ"},{"surah":80,"ayah":41,"text":"تَرْهَقُهَا قَتَرَةٌ"},{"surah":80,"ayah":42,"text":"أُولَـٰئِكَ هُمُ الْكَفَرَةُ الْفَجَرَةُ"}]}