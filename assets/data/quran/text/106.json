{
  "ayahs": [
    {
      "surah": 106,
      "ayah": 1,
      "text": "بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ لِإِيلَافِ قُرَيْشٍ"
    },
    {
      "surah": 106,
      "ayah": 2,
      "text": "إِيلَافِهِمْ رِحْلَةَ الشِّتَاءِ وَالصَّيْفِ"
    },
    {
      "surah": 106,
      "ayah": 3,
      "text": "فَلْيَعْبُدُوا رَبَّ هَـٰذَا الْبَيْتِ"
    },
    {
      "surah": 106,
      "ayah": 4,
      "text": "الَّذِي أَطْعَمَهُمْ مِنْ جُوعٍ وَآمَنَهُمْ مِنْ خَوْفٍ"
    }
  ]
