{
  "ayahs": [
    {
      "surah": 105,
      "ayah": 1,
      "text": "\u0628\u0650\u0633\u0652\u0645\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0652\u0645\u064e\u0670\u0646\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0650\u064a\u0645\u0650 \u0623\u064e\u0644\u064e\u0645\u0652 \u062a\u064e\u0631\u064e \u0643\u064e\u064a\u0652\u0641\u064e \u0641\u064e\u0639\u064e\u0644\u064e \u0631\u064e\u0628\u0651\u064f\u0643\u064e \u0628\u0650\u0623\u064e\u0635\u0652\u062d\u064e\u0670\u0628\u0650 \u0671\u0644\u0652\u0641\u0650\u064a\u0644\u0650"
    },
    {
      "surah": 105,
      "ayah": 2,
      "text": "\u0623\u064e\u0644\u064e\u0645\u0652 \u064a\u064e\u062c\u0652\u0639\u064e\u0644\u0652 \u0643\u064e\u064a\u0652\u062f\u064e\u0647\u064f\u0645\u0652 \u0641\u0650\u0649 \u062a\u064e\u0636\u0652\u0644\u0650\u064a\u0644\u064d\u06e2"
    },
    {
      "surah": 105,
      "ayah": 3,
      "text": "\u0648\u064e\u0623\u064e\u0631\u0652\u0633\u064e\u0644\u064e \u0639\u064e\u0644\u064e\u064a\u0652\u0647\u0650\u0645\u0652 \u0637\u064e\u064a\u0652\u0631\u064b\u0627 \u0623\u064e\u0628\u064e\u0627\u0628\u0650\u064a\u0644\u064e"
    },
    {
      "surah": 105,
      "ayah": 4,
      "text": "\u062a\u064e\u0631\u0652\u0645\u0650\u064a\u0647\u0650\u0645 \u0628\u0650\u062d\u0650\u062c\u064e\u0627\u0631\u064e\u0629\u064d\u06e2 \u0645\u0651\u0650\u0646 \u0633\u0650\u062c\u0651\u0650\u064a\u0644\u064d\u06e2"
    },
    {
      "surah": 105,
      "ayah": 5,
      "text": "\u0641\u064e\u062c\u064e\u0639\u064e\u0644\u064e\u0647\u064f\u0645\u0652 \u0643\u064e\u0639\u064e\u0635\u0652\u0641\u064d\u06e2 \u0645\u0651\u064e\u0623\u0652\u0643\u064f\u0648\u0644\u064d\u06ed"
    }
  ]
