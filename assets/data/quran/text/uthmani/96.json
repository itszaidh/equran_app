{
  "ayahs": [
    {
      "surah": 96,
      "ayah": 1,
      "text": "\u0628\u0650\u0633\u0652\u0645\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0652\u0645\u064e\u0670\u0646\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0650\u064a\u0645\u0650 \u0671\u0642\u0652\u0631\u064e\u0623\u0652 \u0628\u0650\u0671\u0633\u0652\u0645\u0650 \u0631\u064e\u0628\u0651\u0650\u0643\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u0649 \u062e\u064e\u0644\u064e\u0642\u064e"
    },
    {
      "surah": 96,
      "ayah": 2,
      "text": "\u062e\u064e\u0644\u064e\u0642\u064e \u0671\u0644\u0652\u0625\u0650\u0646\u0633\u064e\u0670\u0646\u064e \u0645\u0650\u0646\u0652 \u0639\u064e\u0644\u064e\u0642\u064d"
    },
    {
      "surah": 96,
      "ayah": 3,
      "text": "\u0671\u0642\u0652\u0631\u064e\u0623\u0652 \u0648\u064e\u0631\u064e\u0628\u0651\u064f\u0643\u064e \u0671\u0644\u0652\u0623\u064e\u0643\u0652\u0631\u064e\u0645\u064f"
    },
    {
      "surah": 96,
      "ayah": 4,
      "text": "\u0671\u0644\u0651\u064e\u0630\u0650\u0649 \u0639\u064e\u0644\u0651\u064e\u0645\u064e \u0628\u0650\u0671\u0644\u0652\u0642\u064e\u0644\u064e\u0645\u0650"
    },
    {
      "surah": 96,
      "ayah": 5,
      "text": "\u0639\u064e\u0644\u0651\u064e\u0645\u064e \u0671\u0644\u0652\u0625\u0650\u0646\u0633\u064e\u0670\u0646\u064e \u0645\u064e\u0627 \u0644\u064e\u0645\u0652 \u064a\u064e\u0639\u0652\u0644\u064e\u0645\u0652"
    },
    {
      "surah": 96,
      "ayah": 6,
      "text": "\u0643\u064e\u0644\u0651\u064e\u0627\u0653 \u0625\u0650\u0646\u0651\u064e \u0671\u0644\u0652\u0625\u0650\u0646\u0633\u064e\u0670\u0646\u064e \u0644\u064e\u064a\u064e\u0637\u0652\u063a\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 96,
      "ayah": 7,
      "text": "\u0623\u064e\u0646 \u0631\u0651\u064e\u0621\u064e\u0627\u0647\u064f \u0671\u0633\u0652\u062a\u064e\u063a\u0652\u0646\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 96,
      "ayah": 8,
      "text": "\u0625\u0650\u0646\u0651\u064e \u0625\u0650\u0644\u064e\u0649\u0670 \u0631\u064e\u0628\u0651\u0650\u0643\u064e \u0671\u0644\u0631\u0651\u064f\u062c\u0652\u0639\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 96,
      "ayah": 9,
      "text": "\u0623\u064e\u0631\u064e\u0621\u064e\u064a\u0652\u062a\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u0649 \u064a\u064e\u0646\u0652\u0647\u064e\u0649\u0670"
    },
    {
      "surah": 96,
      "ayah": 10,
      "text": "\u0639\u064e\u0628\u0652\u062f\u064b\u0627 \u0625\u0650\u0630\u064e\u0627 \u0635\u064e\u0644\u0651\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 96,
      "ayah": 11,
      "text": "\u0623\u064e\u0631\u064e\u0621\u064e\u064a\u0652\u062a\u064e \u0625\u0650\u0646 \u0643\u064e\u0627\u0646\u064e \u0639\u064e\u0644\u064e\u0649 \u0671\u0644\u0652\u0647\u064f\u062f\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 96,
      "ayah": 12,
      "text": "\u0623\u064e\u0648\u0652 \u0623\u064e\u0645\u064e\u0631\u064e \u0628\u0650\u0671\u0644\u062a\u0651\u064e\u0642\u0652\u0648\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 96,
      "ayah": 13,
      "text": "\u0623\u064e\u0631\u064e\u0621\u064e\u064a\u0652\u062a\u064e \u0625\u0650\u0646 \u0643\u064e\u0630\u0651\u064e\u0628\u064e \u0648\u064e\u062a\u064e\u0648\u064e\u0644\u0651\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 96,
      "ayah": 14,
      "text": "\u0623\u064e\u0644\u064e\u0645\u0652 \u064a\u064e\u0639\u0652\u0644\u064e\u0645 \u0628\u0650\u0623\u064e\u0646\u0651\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064e \u064a\u064e\u0631\u064e\u0649\u0670"
    },
    {
      "surah": 96,
      "ayah": 15,
      "text": "\u0643\u064e\u0644\u0651\u064e\u0627 \u0644\u064e\u0626\u0650\u0646 \u0644\u0651\u064e\u0645\u0652 \u064a\u064e\u0646\u062a\u064e\u0647\u0650 \u0644\u064e\u0646\u064e\u0633\u0652\u0641\u064e\u0639\u064b\u06e2\u0627 \u0628\u0650\u0671\u0644\u0646\u0651\u064e\u0627\u0635\u0650\u064a\u064e\u0629\u0650"
    },
    {
      "surah": 96,
      "ayah": 16,
      "text": "\u0646\u064e\u0627\u0635\u0650\u064a\u064e\u0629\u064d\u06e2 \u0643\u064e\u0670\u0630\u0650\u0628\u064e\u0629\u064d \u062e\u064e\u0627\u0637\u0650\u0626\u064e\u0629\u064d\u06e2"
    },
    {
      "surah": 96,
      "ayah": 17,
      "text": "\u0641\u064e\u0644\u0652\u064a\u064e\u062f\u0652\u0639\u064f \u0646\u064e\u0627\u062f\u0650\u064a\u064e\u0647\u064f\u06e5"
    },
    {
      "surah": 96,
      "ayah": 18,
      "text": "\u0633\u064e\u0646\u064e\u062f\u0652\u0639\u064f \u0671\u0644\u0632\u0651\u064e\u0628\u064e\u0627\u0646\u0650\u064a\u064e\u0629\u064e"
    },
    {
      "surah": 96,
      "ayah": 19,
      "text": "\u0643\u064e\u0644\u0651\u064e\u0627 \u0644\u064e\u0627 \u062a\u064f\u0637\u0650\u0639\u0652\u0647\u064f \u0648\u064e\u0671\u0633\u0652\u062c\u064f\u062f\u0652 \u0648\u064e\u0671\u0642\u0652\u062a\u064e\u0631\u0650\u0628 \u06e9"
    }
  ]
}