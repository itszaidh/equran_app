{
  "ayahs": [
    {
      "surah": 75,
      "ayah": 1,
      "text": "\u0628\u0650\u0633\u0652\u0645\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0652\u0645\u064e\u0670\u0646\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0650\u064a\u0645\u0650 \u0644\u064e\u0627\u0653 \u0623\u064f\u0642\u0652\u0633\u0650\u0645\u064f \u0628\u0650\u064a\u064e\u0648\u0652\u0645\u0650 \u0671\u0644\u0652\u0642\u0650\u064a\u064e\u0670\u0645\u064e\u0629\u0650"
    },
    {
      "surah": 75,
      "ayah": 2,
      "text": "\u0648\u064e\u0644\u064e\u0627\u0653 \u0623\u064f\u0642\u0652\u0633\u0650\u0645\u064f \u0628\u0650\u0671\u0644\u0646\u0651\u064e\u0641\u0652\u0633\u0650 \u0671\u0644\u0644\u0651\u064e\u0648\u0651\u064e\u0627\u0645\u064e\u0629\u0650"
    },
    {
      "surah": 75,
      "ayah": 3,
      "text": "\u0623\u064e\u064a\u064e\u062d\u0652\u0633\u064e\u0628\u064f \u0671\u0644\u0652\u0625\u0650\u0646\u0633\u064e\u0670\u0646\u064f \u0623\u064e\u0644\u0651\u064e\u0646 \u0646\u0651\u064e\u062c\u0652\u0645\u064e\u0639\u064e \u0639\u0650\u0638\u064e\u0627\u0645\u064e\u0647\u064f\u06e5"
    },
    {
      "surah": 75,
      "ayah": 4,
      "text": "\u0628\u064e\u0644\u064e\u0649\u0670 \u0642\u064e\u0670\u062f\u0650\u0631\u0650\u064a\u0646\u064e \u0639\u064e\u0644\u064e\u0649\u0670\u0653 \u0623\u064e\u0646 \u0646\u0651\u064f\u0633\u064e\u0648\u0651\u0650\u0649\u064e \u0628\u064e\u0646\u064e\u0627\u0646\u064e\u0647\u064f\u06e5"
    },
    {
      "surah": 75,
      "ayah": 5,
      "text": "\u0628\u064e\u0644\u0652 \u064a\u064f\u0631\u0650\u064a\u062f\u064f \u0671\u0644\u0652\u0625\u0650\u0646\u0633\u064e\u0670\u0646\u064f \u0644\u0650\u064a\u064e\u0641\u0652\u062c\u064f\u0631\u064e \u0623\u064e\u0645\u064e\u0627\u0645\u064e\u0647\u064f\u06e5"
    },
    {
      "surah": 75,
      "ayah": 6,
      "text": "\u064a\u064e\u0633\u0652\u0640\u0654\u064e\u0644\u064f \u0623\u064e\u064a\u0651\u064e\u0627\u0646\u064e \u064a\u064e\u0648\u0652\u0645\u064f \u0671\u0644\u0652\u0642\u0650\u064a\u064e\u0670\u0645\u064e\u0629\u0650"
    },
    {
      "surah": 75,
      "ayah": 7,
      "text": "\u0641\u064e\u0625\u0650\u0630\u064e\u0627 \u0628\u064e\u0631\u0650\u0642\u064e \u0671\u0644\u0652\u0628\u064e\u0635\u064e\u0631\u064f"
    },
    {
      "surah": 75,
      "ayah": 8,
      "text": "\u0648\u064e\u062e\u064e\u0633\u064e\u0641\u064e \u0671\u0644\u0652\u0642\u064e\u0645\u064e\u0631\u064f"
    },
    {
      "surah": 75,
      "ayah": 9,
      "text": "\u0648\u064e\u062c\u064f\u0645\u0650\u0639\u064e \u0671\u0644\u0634\u0651\u064e\u0645\u0652\u0633\u064f \u0648\u064e\u0671\u0644\u0652\u0642\u064e\u0645\u064e\u0631\u064f"
    },
    {
      "surah": 75,
      "ayah": 10,
      "text": "\u064a\u064e\u0642\u064f\u0648\u0644\u064f \u0671\u0644\u0652\u0625\u0650\u0646\u0633\u064e\u0670\u0646\u064f \u064a\u064e\u0648\u0652\u0645\u064e\u0626\u0650\u0630\u064d \u0623\u064e\u064a\u0652\u0646\u064e \u0671\u0644\u0652\u0645\u064e\u0641\u064e\u0631\u0651\u064f"
    },
    {
      "surah": 75,
      "ayah": 11,
      "text": "\u0643\u064e\u0644\u0651\u064e\u0627 \u0644\u064e\u0627 \u0648\u064e\u0632\u064e\u0631\u064e"
    },
    {
      "surah": 75,
      "ayah": 12,
      "text": "\u0625\u0650\u0644\u064e\u0649\u0670 \u0631\u064e\u0628\u0651\u0650\u0643\u064e \u064a\u064e\u0648\u0652\u0645\u064e\u0626\u0650\u0630\u064d \u0671\u0644\u0652\u0645\u064f\u0633\u0652\u062a\u064e\u0642\u064e\u0631\u0651\u064f"
    },
    {
      "surah": 75,
      "ayah": 13,
      "text": "\u064a\u064f\u0646\u064e\u0628\u0651\u064e\u0624\u064f\u0627\u06df \u0671\u0644\u0652\u0625\u0650\u0646\u0633\u064e\u0670\u0646\u064f \u064a\u064e\u0648\u0652\u0645\u064e\u0626\u0650\u0630\u064d\u06ed \u0628\u0650\u0645\u064e\u0627 \u0642\u064e\u062f\u0651\u064e\u0645\u064e \u0648\u064e\u0623\u064e\u062e\u0651\u064e\u0631\u064e"
    },
    {
      "surah": 75,
      "ayah": 14,
      "text": "\u0628\u064e\u0644\u0650 \u0671\u0644\u0652\u0625\u0650\u0646\u0633\u064e\u0670\u0646\u064f \u0639\u064e\u0644\u064e\u0649\u0670 \u0646\u064e\u0641\u0652\u0633\u0650\u0647\u0650\u06e6 \u0628\u064e\u0635\u0650\u064a\u0631\u064e\u0629\u064c\u06ed"
    },
    {
      "surah": 75,
      "ayah": 15,
      "text": "\u0648\u064e\u0644\u064e\u0648\u0652 \u0623\u064e\u0644\u0652\u0642\u064e\u0649\u0670 \u0645\u064e\u0639\u064e\u0627\u0630\u0650\u064a\u0631\u064e\u0647\u064f\u06e5"
    },
    {
      "surah": 75,
      "ayah": 16,
      "text": "\u0644\u064e\u0627 \u062a\u064f\u062d\u064e\u0631\u0651\u0650\u0643\u0652 \u0628\u0650\u0647\u0650\u06e6 \u0644\u0650\u0633\u064e\u0627\u0646\u064e\u0643\u064e \u0644\u0650\u062a\u064e\u0639\u0652\u062c\u064e\u0644\u064e \u0628\u0650\u0647\u0650\u06e6\u0653"
    },
    {
      "surah": 75,
      "ayah": 17,
      "text": "\u0625\u0650\u0646\u0651\u064e \u0639\u064e\u0644\u064e\u064a\u0652\u0646\u064e\u0627 \u062c\u064e\u0645\u0652\u0639\u064e\u0647\u064f\u06e5 \u0648\u064e\u0642\u064f\u0631\u0652\u0621\u064e\u0627\u0646\u064e\u0647\u064f\u06e5"
    },
    {
      "surah": 75,
      "ayah": 18,
      "text": "\u0641\u064e\u0625\u0650\u0630\u064e\u0627 \u0642\u064e\u0631\u064e\u0623\u0652\u0646\u064e\u0670\u0647\u064f \u0641\u064e\u0671\u062a\u0651\u064e\u0628\u0650\u0639\u0652 \u0642\u064f\u0631\u0652\u0621\u064e\u0627\u0646\u064e\u0647\u064f\u06e5"
    },
    {
      "surah": 75,
      "ayah": 19,
      "text": "\u062b\u064f\u0645\u0651\u064e \u0625\u0650\u0646\u0651\u064e \u0639\u064e\u0644\u064e\u064a\u0652\u0646\u064e\u0627 \u0628\u064e\u064a\u064e\u0627\u0646\u064e\u0647\u064f\u06e5"
    },
    {
      "surah": 75,
      "ayah": 20,
      "text": "\u0643\u064e\u0644\u0651\u064e\u0627 \u0628\u064e\u0644\u0652 \u062a\u064f\u062d\u0650\u0628\u0651\u064f\u0648\u0646\u064e \u0671\u0644\u0652\u0639\u064e\u0627\u062c\u0650\u0644\u064e\u0629\u064e"
    },
    {
      "surah": 75,
      "ayah": 21,
      "text": "\u0648\u064e\u062a\u064e\u0630\u064e\u0631\u064f\u0648\u0646\u064e \u0671\u0644\u0652\u0621\u064e\u0627\u062e\u0650\u0631\u064e\u0629\u064e"
    },
    {
      "surah": 75,
      "ayah": 22,
      "text": "\u0648\u064f\u062c\u064f\u0648\u0647\u064c\u06ed \u064a\u064e\u0648\u0652\u0645\u064e\u0626\u0650\u0630\u064d\u06e2 \u0646\u0651\u064e\u0627\u0636\u0650\u0631\u064e\u0629\u064c"
    },
    {
      "surah": 75,
      "ayah": 23,
      "text": "\u0625\u0650\u0644\u064e\u0649\u0670 \u0631\u064e\u0628\u0651\u0650\u0647\u064e\u0627 \u0646\u064e\u0627\u0638\u0650\u0631\u064e\u0629\u064c\u06ed"
    },
    {
      "surah": 75,
      "ayah": 24,
      "text": "\u0648\u064e\u0648\u064f\u062c\u064f\u0648\u0647\u064c\u06ed \u064a\u064e\u0648\u0652\u0645\u064e\u0626\u0650\u0630\u064d\u06ed \u0628\u064e\u0627\u0633\u0650\u0631\u064e\u0629\u064c\u06ed"
    },
    {
      "surah": 75,
      "ayah": 25,
      "text": "\u062a\u064e\u0638\u064f\u0646\u0651\u064f \u0623\u064e\u0646 \u064a\u064f\u0641\u0652\u0639\u064e\u0644\u064e \u0628\u0650\u0647\u064e\u0627 \u0641\u064e\u0627\u0642\u0650\u0631\u064e\u0629\u064c\u06ed"
    },
    {
      "surah": 75,
      "ayah": 26,
      "text": "\u0643\u064e\u0644\u0651\u064e\u0627\u0653 \u0625\u0650\u0630\u064e\u0627 \u0628\u064e\u0644\u064e\u063a\u064e\u062a\u0650 \u0671\u0644\u062a\u0651\u064e\u0631\u064e\u0627\u0642\u0650\u0649\u064e"
    },
    {
      "surah": 75,
      "ayah": 27,
      "text": "\u0648\u064e\u0642\u0650\u064a\u0644\u064e \u0645\u064e\u0646\u0652 \u06dc \u0631\u064e\u0627\u0642\u064d\u06e2"
    },
    {
      "surah": 75,
      "ayah": 28,
      "text": "\u0648\u064e\u0638\u064e\u0646\u0651\u064e \u0623\u064e\u0646\u0651\u064e\u0647\u064f \u0671\u0644\u0652\u0641\u0650\u0631\u064e\u0627\u0642\u064f"
    },
    {
      "surah": 75,
      "ayah": 29,
      "text": "\u0648\u064e\u0671\u0644\u0652\u062a\u064e\u0641\u0651\u064e\u062a\u0650 \u0671\u0644\u0633\u0651\u064e\u0627\u0642\u064f \u0628\u0650\u0671\u0644\u0633\u0651\u064e\u0627\u0642\u0650"
    },
    {
      "surah": 75,
      "ayah": 30,
      "text": "\u0625\u0650\u0644\u064e\u0649\u0670 \u0631\u064e\u0628\u0651\u0650\u0643\u064e \u064a\u064e\u0648\u0652\u0645\u064e\u0626\u0650\u0630\u064d \u0671\u0644\u0652\u0645\u064e\u0633\u064e\u0627\u0642\u064f"
    },
    {
      "surah": 75,
      "ayah": 31,
      "text": "\u0641\u064e\u0644\u064e\u0627 \u0635\u064e\u062f\u0651\u064e\u0642\u064e \u0648\u064e\u0644\u064e\u0627 \u0635\u064e\u0644\u0651\u064e\u0649\u0670"
    },
    {
      "surah": 75,
      "ayah": 32,
      "text": "\u0648\u064e\u0644\u064e\u0670\u0643\u0650\u0646 \u0643\u064e\u0630\u0651\u064e\u0628\u064e \u0648\u064e\u062a\u064e\u0648\u064e\u0644\u0651\u064e\u0649\u0670"
    },
    {
      "surah": 75,
      "ayah": 33,
      "text": "\u062b\u064f\u0645\u0651\u064e \u0630\u064e\u0647\u064e\u0628\u064e \u0625\u0650\u0644\u064e\u0649\u0670\u0653 \u0623\u064e\u0647\u0652\u0644\u0650\u0647\u0650\u06e6 \u064a\u064e\u062a\u064e\u0645\u064e\u0637\u0651\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 75,
      "ayah": 34,
      "text": "\u0623\u064e\u0648\u0652\u0644\u064e\u0649\u0670 \u0644\u064e\u0643\u064e \u0641\u064e\u0623\u064e\u0648\u0652\u0644\u064e\u0649\u0670"
    },
    {
      "surah": 75,
      "ayah": 35,
      "text": "\u062b\u064f\u0645\u0651\u064e \u0623\u064e\u0648\u0652\u0644\u064e\u0649\u0670 \u0644\u064e\u0643\u064e \u0641\u064e\u0623\u064e\u0648\u0652\u0644\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 75,
      "ayah": 36,
      "text": "\u0623\u064e\u064a\u064e\u062d\u0652\u0633\u064e\u0628\u064f \u0671\u0644\u0652\u0625\u0650\u0646\u0633\u064e\u0670\u0646\u064f \u0623\u064e\u0646 \u064a\u064f\u062a\u0652\u0631\u064e\u0643\u064e \u0633\u064f\u062f\u064b\u0649"
    },
    {
      "surah": 75,
      "ayah": 37,
      "text": "\u0623\u064e\u0644\u064e\u0645\u0652 \u064a\u064e\u0643\u064f \u0646\u064f\u0637\u0652\u0641\u064e\u0629\u064b\u06ed \u0645\u0651\u0650\u0646 \u0645\u0651\u064e\u0646\u0650\u0649\u0651\u064d\u06e2 \u064a\u064f\u0645\u0652\u0646\u064e\u0649\u0670"
    },
    {
      "surah": 75,
      "ayah": 38,
      "text": "\u062b\u064f\u0645\u0651\u064e \u0643\u064e\u0627\u0646\u064e \u0639\u064e\u0644\u064e\u0642\u064e\u0629\u064b\u06ed \u0641\u064e\u062e\u064e\u0644\u064e\u0642\u064e \u0641\u064e\u0633\u064e\u0648\u0651\u064e\u0649\u0670"
    },
    {
      "surah": 75,
      "ayah": 39,
      "text": "\u0641\u064e\u062c\u064e\u0639\u064e\u0644\u064e \u0645\u0650\u0646\u0652\u0647\u064f \u0671\u0644\u0632\u0651\u064e\u0648\u0652\u062c\u064e\u064a\u0652\u0646\u0650 \u0671\u0644\u0630\u0651\u064e\u0643\u064e\u0631\u064e \u0648\u064e\u0671\u0644\u0652\u0623\u064f\u0646\u062b\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 75,
      "ayah": 40,
      "text": "\u0623\u064e\u0644\u064e\u064a\u0652\u0633\u064e \u0630\u064e\u0670\u0644\u0650\u0643\u064e \u0628\u0650\u0642\u064e\u0670\u062f\u0650\u0631\u064d \u0639\u064e\u0644\u064e\u0649\u0670\u0653 \u0623\u064e\u0646 \u064a\u064f\u062d\u0652\u06e6\u0650\u0649\u064e \u0671\u0644\u0652\u0645\u064e\u0648\u0652\u062a\u064e\u0649\u0670"
    }
  ]
}