      "ayah": 33,
      "text": "\u0623\u064e\u0641\u064e\u0631\u064e\u0621\u064e\u064a\u0652\u062a\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u0649 \u062a\u064e\u0648\u064e\u0644\u0651\u064e\u0649\u0670"
    },
    {
