      "ayah": 59,
      "text": "\u0623\u064e\u0641\u064e\u0645\u0650\u0646\u0652 \u0647\u064e\u0670\u0630\u064e\u0627 \u0671\u0644\u0652\u062d\u064e\u062f\u0650\u064a\u062b\u0650 \u062a\u064e\u0639\u0652\u062c\u064e\u0628\u064f\u0648\u0646\u064e"
