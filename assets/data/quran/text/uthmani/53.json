      "text": "\u0644\u064e\u064a\u0652\u0633\u064e \u0644\u064e\u0647\u064e\u0627 \u0645\u0650\u0646 \u062f\u064f\u0648\u0646\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0643\u064e\u0627\u0634\u0650\u0641\u064e\u0629\u064c"
