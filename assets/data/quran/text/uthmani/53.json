      "text": "\u0648\u064e\u062a\u064e\u0636\u0652\u062d\u064e\u0643\u064f\u0648\u0646\u064e \u0648\u064e\u0644\u064e\u0627 \u062a\u064e\u0628\u0652\u0643\u064f\u0648\u0646\u064e"
