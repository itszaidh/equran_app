{
  "ayahs": [
    {
      "surah": 53,
      "ayah": 1,
      "text": "\u0628\u0650\u0633\u0652\u0645\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0652\u0645\u064e\u0670\u0646\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0650\u064a\u0645\u0650 \u0648\u064e\u0671\u0644\u0646\u0651\u064e\u062c\u0652\u0645\u0650 \u0625\u0650\u0630\u064e\u0627 \u0647\u064e\u0648\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 2,
      "text": "\u0645\u064e\u0627 \u0636\u064e\u0644\u0651\u064e \u0635\u064e\u0627\u062d\u0650\u0628\u064f\u0643\u064f\u0645\u0652 \u0648\u064e\u0645\u064e\u0627 \u063a\u064e\u0648\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 3,
      "text": "\u0648\u064e\u0645\u064e\u0627 \u064a\u064e\u0646\u0637\u0650\u0642\u064f \u0639\u064e\u0646\u0650 \u0671\u0644\u0652\u0647\u064e\u0648\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 53,
      "ayah": 4,
      "text": "\u0625\u0650\u0646\u0652 \u0647\u064f\u0648\u064e \u0625\u0650\u0644\u0651\u064e\u0627 \u0648\u064e\u062d\u0652\u0649\u064c\u06ed \u064a\u064f\u0648\u062d\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 5,
      "text": "\u0639\u064e\u0644\u0651\u064e\u0645\u064e\u0647\u064f\u06e5 \u0634\u064e\u062f\u0650\u064a\u062f\u064f \u0671\u0644\u0652\u0642\u064f\u0648\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 6,
      "text": "\u0630\u064f\u0648 \u0645\u0650\u0631\u0651\u064e\u0629\u064d\u06e2 \u0641\u064e\u0671\u0633\u0652\u062a\u064e\u0648\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 7,
      "text": "\u0648\u064e\u0647\u064f\u0648\u064e \u0628\u0650\u0671\u0644\u0652\u0623\u064f\u0641\u064f\u0642\u0650 \u0671\u0644\u0652\u0623\u064e\u0639\u0652\u0644\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 8,
      "text": "\u062b\u064f\u0645\u0651\u064e \u062f\u064e\u0646\u064e\u0627 \u0641\u064e\u062a\u064e\u062f\u064e\u0644\u0651\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 9,
      "text": "\u0641\u064e\u0643\u064e\u0627\u0646\u064e \u0642\u064e\u0627\u0628\u064e \u0642\u064e\u0648\u0652\u0633\u064e\u064a\u0652\u0646\u0650 \u0623\u064e\u0648\u0652 \u0623\u064e\u062f\u0652\u0646\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 10,
      "text": "\u0641\u064e\u0623\u064e\u0648\u0652\u062d\u064e\u0649\u0670\u0653 \u0625\u0650\u0644\u064e\u0649\u0670 \u0639\u064e\u0628\u0652\u062f\u0650\u0647\u0650\u06e6 \u0645\u064e\u0627\u0653 \u0623\u064e\u0648\u0652\u062d\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 11,
      "text": "\u0645\u064e\u0627 \u0643\u064e\u0630\u064e\u0628\u064e \u0671\u0644\u0652\u0641\u064f\u0624\u064e\u0627\u062f\u064f \u0645\u064e\u0627 \u0631\u064e\u0623\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 53,
      "ayah": 12,
      "text": "\u0623\u064e\u0641\u064e\u062a\u064f\u0645\u064e\u0670\u0631\u064f\u0648\u0646\u064e\u0647\u064f\u06e5 \u0639\u064e\u0644\u064e\u0649\u0670 \u0645\u064e\u0627 \u064a\u064e\u0631\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 13,
      "text": "\u0648\u064e\u0644\u064e\u0642\u064e\u062f\u0652 \u0631\u064e\u0621\u064e\u0627\u0647\u064f \u0646\u064e\u0632\u0652\u0644\u064e\u0629\u064b \u0623\u064f\u062e\u0652\u0631\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 14,
      "text": "\u0639\u0650\u0646\u062f\u064e \u0633\u0650\u062f\u0652\u0631\u064e\u0629\u0650 \u0671\u0644\u0652\u0645\u064f\u0646\u062a\u064e\u0647\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 15,
      "text": "\u0639\u0650\u0646\u062f\u064e\u0647\u064e\u0627 \u062c\u064e\u0646\u0651\u064e\u0629\u064f \u0671\u0644\u0652\u0645\u064e\u0623\u0652\u0648\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 53,
      "ayah": 16,
      "text": "\u0625\u0650\u0630\u0652 \u064a\u064e\u063a\u0652\u0634\u064e\u0649 \u0671\u0644\u0633\u0651\u0650\u062f\u0652\u0631\u064e\u0629\u064e \u0645\u064e\u0627 \u064a\u064e\u063a\u0652\u0634\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 17,
      "text": "\u0645\u064e\u0627 \u0632\u064e\u0627\u063a\u064e \u0671\u0644\u0652\u0628\u064e\u0635\u064e\u0631\u064f \u0648\u064e\u0645\u064e\u0627 \u0637\u064e\u063a\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 18,
      "text": "\u0644\u064e\u0642\u064e\u062f\u0652 \u0631\u064e\u0623\u064e\u0649\u0670 \u0645\u0650\u0646\u0652 \u0621\u064e\u0627\u064a\u064e\u0670\u062a\u0650 \u0631\u064e\u0628\u0651\u0650\u0647\u0650 \u0671\u0644\u0652\u0643\u064f\u0628\u0652\u0631\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 53,
      "ayah": 19,
      "text": "\u0623\u064e\u0641\u064e\u0631\u064e\u0621\u064e\u064a\u0652\u062a\u064f\u0645\u064f \u0671\u0644\u0644\u0651\u064e\u0670\u062a\u064e \u0648\u064e\u0671\u0644\u0652\u0639\u064f\u0632\u0651\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 20,
      "text": "\u0648\u064e\u0645\u064e\u0646\u064e\u0648\u0670\u0629\u064e \u0671\u0644\u062b\u0651\u064e\u0627\u0644\u0650\u062b\u064e\u0629\u064e \u0671\u0644\u0652\u0623\u064f\u062e\u0652\u0631\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 53,
      "ayah": 21,
      "text": "\u0623\u064e\u0644\u064e\u0643\u064f\u0645\u064f \u0671\u0644\u0630\u0651\u064e\u0643\u064e\u0631\u064f \u0648\u064e\u0644\u064e\u0647\u064f \u0671\u0644\u0652\u0623\u064f\u0646\u062b\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 22,
      "text": "\u062a\u0650\u0644\u0652\u0643\u064e \u0625\u0650\u0630\u064b\u06ed\u0627 \u0642\u0650\u0633\u0652\u0645\u064e\u0629\u064c\u06ed \u0636\u0650\u064a\u0632\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 53,
      "ayah": 23,
      "text": "\u0625\u0650\u0646\u0652 \u0647\u0650\u0649\u064e \u0625\u0650\u0644\u0651\u064e\u0627\u0653 \u0623\u064e\u0633\u0652\u0645\u064e\u0627\u0653\u0621\u064c\u06ed \u0633\u064e\u0645\u0651\u064e\u064a\u0652\u062a\u064f\u0645\u064f\u0648\u0647\u064e\u0627\u0653 \u0623\u064e\u0646\u062a\u064f\u0645\u0652 \u0648\u064e\u0621\u064e\u0627\u0628\u064e\u0627\u0653\u0624\u064f\u0643\u064f\u0645 \u0645\u0651\u064e\u0627\u0653 \u0623\u064e\u0646\u0632\u064e\u0644\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0628\u0650\u0647\u064e\u0627 \u0645\u0650\u0646 \u0633\u064f\u0644\u0652\u0637\u064e\u0670\u0646\u064d \u06da \u0625\u0650\u0646 \u064a\u064e\u062a\u0651\u064e\u0628\u0650\u0639\u064f\u0648\u0646\u064e \u0625\u0650\u0644\u0651\u064e\u0627 \u0671\u0644\u0638\u0651\u064e\u0646\u0651\u064e \u0648\u064e\u0645\u064e\u0627 \u062a\u064e\u0647\u0652\u0648\u064e\u0649 \u0671\u0644\u0652\u0623\u064e\u0646\u0641\u064f\u0633\u064f \u06d6 \u0648\u064e\u0644\u064e\u0642\u064e\u062f\u0652 \u062c\u064e\u0627\u0653\u0621\u064e\u0647\u064f\u0645 \u0645\u0651\u0650\u0646 \u0631\u0651\u064e\u0628\u0651\u0650\u0647\u0650\u0645\u064f \u0671\u0644\u0652\u0647\u064f\u062f\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 53,
      "ayah": 24,
      "text": "\u0623\u064e\u0645\u0652 \u0644\u0650\u0644\u0652\u0625\u0650\u0646\u0633\u064e\u0670\u0646\u0650 \u0645\u064e\u0627 \u062a\u064e\u0645\u064e\u0646\u0651\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 25,
      "text": "\u0641\u064e\u0644\u0650\u0644\u0651\u064e\u0647\u0650 \u0671\u0644\u0652\u0621\u064e\u0627\u062e\u0650\u0631\u064e\u0629\u064f \u0648\u064e\u0671\u0644\u0652\u0623\u064f\u0648\u0644\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 26,
      "text": "\u06de \u0648\u064e\u0643\u064e\u0645 \u0645\u0651\u0650\u0646 \u0645\u0651\u064e\u0644\u064e\u0643\u064d\u06e2 \u0641\u0650\u0649 \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0644\u064e\u0627 \u062a\u064f\u063a\u0652\u0646\u0650\u0649 \u0634\u064e\u0641\u064e\u0670\u0639\u064e\u062a\u064f\u0647\u064f\u0645\u0652 \u0634\u064e\u064a\u0652\u0640\u0654\u064b\u0627 \u0625\u0650\u0644\u0651\u064e\u0627 \u0645\u0650\u0646\u06e2 \u0628\u064e\u0639\u0652\u062f\u0650 \u0623\u064e\u0646 \u064a\u064e\u0623\u0652\u0630\u064e\u0646\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0644\u0650\u0645\u064e\u0646 \u064a\u064e\u0634\u064e\u0627\u0653\u0621\u064f \u0648\u064e\u064a\u064e\u0631\u0652\u0636\u064e\u0649\u0670\u0653"
    },
    {
      "surah": 53,
      "ayah": 27,
      "text": "\u0625\u0650\u0646\u0651\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0644\u064e\u0627 \u064a\u064f\u0624\u0652\u0645\u0650\u0646\u064f\u0648\u0646\u064e \u0628\u0650\u0671\u0644\u0652\u0621\u064e\u0627\u062e\u0650\u0631\u064e\u0629\u0650 \u0644\u064e\u064a\u064f\u0633\u064e\u0645\u0651\u064f\u0648\u0646\u064e \u0671\u0644\u0652\u0645\u064e\u0644\u064e\u0670\u0653\u0626\u0650\u0643\u064e\u0629\u064e \u062a\u064e\u0633\u0652\u0645\u0650\u064a\u064e\u0629\u064e \u0671\u0644\u0652\u0623\u064f\u0646\u062b\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 28,
      "text": "\u0648\u064e\u0645\u064e\u0627 \u0644\u064e\u0647\u064f\u0645 \u0628\u0650\u0647\u0650\u06e6 \u0645\u0650\u0646\u0652 \u0639\u0650\u0644\u0652\u0645\u064d \u06d6 \u0625\u0650\u0646 \u064a\u064e\u062a\u0651\u064e\u0628\u0650\u0639\u064f\u0648\u0646\u064e \u0625\u0650\u0644\u0651\u064e\u0627 \u0671\u0644\u0638\u0651\u064e\u0646\u0651\u064e \u06d6 \u0648\u064e\u0625\u0650\u0646\u0651\u064e \u0671\u0644\u0638\u0651\u064e\u0646\u0651\u064e \u0644\u064e\u0627 \u064a\u064f\u063a\u0652\u0646\u0650\u0649 \u0645\u0650\u0646\u064e \u0671\u0644\u0652\u062d\u064e\u0642\u0651\u0650 \u0634\u064e\u064a\u0652\u0640\u0654\u064b\u06ed\u0627"
    },
    {
      "surah": 53,
      "ayah": 29,
      "text": "\u0641\u064e\u0623\u064e\u0639\u0652\u0631\u0650\u0636\u0652 \u0639\u064e\u0646 \u0645\u0651\u064e\u0646 \u062a\u064e\u0648\u064e\u0644\u0651\u064e\u0649\u0670 \u0639\u064e\u0646 \u0630\u0650\u0643\u0652\u0631\u0650\u0646\u064e\u0627 \u0648\u064e\u0644\u064e\u0645\u0652 \u064a\u064f\u0631\u0650\u062f\u0652 \u0625\u0650\u0644\u0651\u064e\u0627 \u0671\u0644\u0652\u062d\u064e\u064a\u064e\u0648\u0670\u0629\u064e \u0671\u0644\u062f\u0651\u064f\u0646\u0652\u064a\u064e\u0627"
    },
    {
      "surah": 53,
      "ayah": 30,
      "text": "\u0630\u064e\u0670\u0644\u0650\u0643\u064e \u0645\u064e\u0628\u0652\u0644\u064e\u063a\u064f\u0647\u064f\u0645 \u0645\u0651\u0650\u0646\u064e \u0671\u0644\u0652\u0639\u0650\u0644\u0652\u0645\u0650 \u06da \u0625\u0650\u0646\u0651\u064e \u0631\u064e\u0628\u0651\u064e\u0643\u064e \u0647\u064f\u0648\u064e \u0623\u064e\u0639\u0652\u0644\u064e\u0645\u064f \u0628\u0650\u0645\u064e\u0646 \u0636\u064e\u0644\u0651\u064e \u0639\u064e\u0646 \u0633\u064e\u0628\u0650\u064a\u0644\u0650\u0647\u0650\u06e6 \u0648\u064e\u0647\u064f\u0648\u064e \u0623\u064e\u0639\u0652\u0644\u064e\u0645\u064f \u0628\u0650\u0645\u064e\u0646\u0650 \u0671\u0647\u0652\u062a\u064e\u062f\u064e\u0649\u0670"
    },
    {
      "surah": 53,
      "ayah": 31,
      "text": "\u0648\u064e\u0644\u0650\u0644\u0651\u064e\u0647\u0650 \u0645\u064e\u0627 \u0641\u0650\u0649 \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0645\u064e\u0627 \u0641\u0650\u0649 \u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u0644\u0650\u064a\u064e\u062c\u0652\u0632\u0650\u0649\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0623\u064e\u0633\u064e\u0670\u0653\u0640\u0654\u064f\u0648\u0627\u06df \u0628\u0650\u0645\u064e\u0627 \u0639\u064e\u0645\u0650\u0644\u064f\u0648\u0627\u06df \u0648\u064e\u064a\u064e\u062c\u0652\u0632\u0650\u0649\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0623\u064e\u062d\u0652\u0633\u064e\u0646\u064f\u0648\u0627\u06df \u0628\u0650\u0671\u0644\u0652\u062d\u064f\u0633\u0652\u0646\u064e\u0649"
    },
    {
      "surah": 53,
      "ayah": 32,
      "text": "\u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u064a\u064e\u062c\u0652\u062a\u064e\u0646\u0650\u0628\u064f\u0648\u0646\u064e \u0643\u064e\u0628\u064e\u0670\u0653\u0626\u0650\u0631\u064e \u0671\u0644\u0652\u0625\u0650\u062b\u0652\u0645\u0650 \u0648\u064e\u0671\u0644\u0652\u0641\u064e\u0648\u064e\u0670\u062d\u0650\u0634\u064e \u0625\u0650\u0644\u0651\u064e\u0627 \u0671\u0644\u0644\u0651\u064e\u0645\u064e\u0645\u064e \u06da \u0625\u0650\u0646\u0651\u064e \u0631\u064e\u0628\u0651\u064e\u0643\u064e \u0648\u064e\u0670\u0633\u0650\u0639\u064f \u0671\u0644\u0652\u0645\u064e\u063a\u0652\u0641\u0650\u0631\u064e\u0629\u0650 \u06da \u0647\u064f\u0648\u064e \u0623\u064e\u0639\u0652\u0644\u064e\u0645\u064f \u0628\u0650\u0643\u064f\u0645\u0652 \u0625\u0650\u0630\u0652 \u0623\u064e\u0646\u0634\u064e\u0623\u064e\u0643\u064f\u0645 \u0645\u0651\u0650\u0646\u064e \u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u0648\u064e\u0625\u0650\u0630\u0652 \u0623\u064e\u0646\u062a\u064f\u0645\u0652 \u0623\u064e\u062c\u0650\u0646\u0651\u064e\u0629\u064c\u06ed \u0641\u0650\u0649 \u0628\u064f\u0637\u064f\u0648\u0646\u0650 \u0623\u064f\u0645\u0651\u064e\u0647\u064e\u0670\u062a\u0650\u0643\u064f\u0645\u0652 \u06d6 \u0641\u064e\u0644\u064e\u0627 \u062a\u064f\u0632\u064e\u0643\u0651\u064f\u0648\u0653\u0627\u06df \u0623\u064e\u0646\u0641\u064f\u0633\u064e\u0643\u064f\u0645\u0652 \u06d6 \u0647\u064f\u0648\u064e \u0623\u064e\u0639\u0652\u0644\u064e\u0645\u064f \u0628\u0650\u0645\u064e\u0646\u0650 \u0671\u062a\u0651\u064e\u0642\u064e\u0649\u0670\u0653"
    },
    {
