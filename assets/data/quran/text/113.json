{"ayahs":[{"surah":113,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ"},{"surah":113,"ayah":2,"text":"مِنْ شَرِّ مَا خَلَقَ"},{"surah":113,"ayah":3,"text":"وَمِنْ شَرِّ غَاسِقٍ إِذَا وَقَبَ"},{"surah":113,"ayah":4,"text":"وَمِنْ شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ"},{"surah":113,"ayah":5,"text":"وَمِنْ شَرِّ حَاسِدٍ إِذَا حَسَدَ"}]}