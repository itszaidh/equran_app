{"ayahs":[{"surah":114,"ayah":1,"text":"بِسْمِ اللَّهِ الرَّحْمَـٰنِ الرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ النَّاسِ"},{"surah":114,"ayah":2,"text":"مَلِكِ النَّاسِ"},{"surah":114,"ayah":3,"text":"إِلَـٰهِ النَّاسِ"},{"surah":114,"ayah":4,"text":"مِنْ شَرِّ الْوَسْوَاسِ الْخَنَّاسِ"},{"surah":114,"ayah":5,"text":"الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ"},{"surah":114,"ayah":6,"text":"مِنَ الْجِنَّةِ وَالنَّاسِ"}]}